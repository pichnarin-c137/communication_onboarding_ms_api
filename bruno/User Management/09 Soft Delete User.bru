meta {
  name: Soft Delete User
  type: http
  seq: 9
}

delete {
  url: {{base_url}}/soft-delete-user/{{user_id}}
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{access_token}}
}

docs {
  Admin only. Soft-deletes a user (sets deleted_at). The user is hidden from normal queries
  but can be restored. Use List Users with only_trashed=true to find soft-deleted users.

  Response:
  {
    "success": true,
    "message": "User soft deleted successfully"
  }
}
