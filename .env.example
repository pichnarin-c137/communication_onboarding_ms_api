APP_NAME="Customer Onboarding Management System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=coms_dev
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail (SMTP — used for OTP delivery)
MAIL_MAILER=smtp
MAIL_ENCRYPTION=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@ecoapsara.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# JWT (RS256 keys generated with: php artisan jwt:generate-keys)
JWT_ACCESS_TOKEN_EXPIRY=1440
JWT_REFRESH_TOKEN_EXPIRY=43200
JWT_PRIVATE_KEY_PATH=keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt_public.pem

# OTP
OTP_LENGTH=4
OTP_EXPIRY_MIN=5
OTP_EXPIRY_MAX=10

# Rate Limiting
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_OTP_ATTEMPTS=5
RATE_LIMIT_WINDOW_MIN=15

# CORS — comma-separated list of allowed origins
# Local dev:        http://localhost:5173
# Production:       https://coms.ecoapsara.com
CORS_ALLOWED_ORIGINS=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/google/callback"
GOOGLE_FRONTEND_REDIRECT_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
COMS_TELEGRAM_SETUP_TOKEN_TTL=3600
COMS_TELEGRAM_MESSAGE_RETRY_LIMIT=3
COMS_TELEGRAM_DEFAULT_LANGUAGE=en

# Role UUIDs (seeded — do not change unless re-seeding)
ROLE_ADMIN_ID=
ROLE_CUSTOMER_ID=
ROLE_SALE_ID=
ROLE_TRAINER_ID=
